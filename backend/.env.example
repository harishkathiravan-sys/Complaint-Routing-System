# Backend Configuration

# Database Configuration
# Options: sqlite, postgresql
DATABASE_TYPE=sqlite

# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/complaint_routing_db

# Security
SECRET_KEY=your-super-secret-key-change-in-production-12345678

# Token Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
SQL_ECHO=false

# Server Configuration
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_RELOAD=true

# CORS Configuration
# For local development:
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# For production with Vercel:
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://complaints.karunya.edu

